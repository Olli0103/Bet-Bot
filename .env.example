# ── Application ──────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
TIMEZONE=Europe/Berlin

# ── APIs ─────────────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key
APISPORTS_API_KEY=your_apisports_key
APISPORTS_BASE_URL=https://v3.football.api-sports.io
NEWSAPI_KEY=your_newsapi_key
NEWSAPI_BASE_URL=https://newsapi.org/v2
SPORTSDB_API_KEY=3
FOOTBALL_DATA_API_KEY=your_football_data_key

# ── Database ─────────────────────────────────────────────────
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/signalbot
REDIS_URL=redis://localhost:6379/0

# ── LLM (Ollama) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:4b

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_CHAT_IDS=id1,id2

# ── Betting ──────────────────────────────────────────────────
LIVE_SPORTS=basketball_nba,soccer_germany_bundesliga,soccer_epl,tennis_atp
INITIAL_BANKROLL=1000.0
TIPICO_TAX_RATE=0.05
TAX_FREE_MODE=false

# ── Risk Guards / EV Thresholds ──────────────────────────────
MIN_EV_DEFAULT=0.01
MIN_EV_LOSING_STREAK=0.02
MIN_EV_DRAWDOWN=0.02
MIN_EV_DEGRADATION=0.015
MIN_EV_GOOD_RUN=0.005

# ── Risk Guards / Confidence Gates ──────────────────────────
MIN_CONF_SOCCER_H2H=0.55
MIN_CONF_SOCCER_TOTALS=0.56
MIN_CONF_SOCCER_SPREAD=0.56
MIN_CONF_TENNIS=0.57
MIN_CONF_BASKETBALL=0.55
MIN_CONF_ICEHOCKEY=0.55
MIN_CONF_AMERICANFOOTBALL=0.55
MIN_CONF_DEFAULT=0.55

# ── Risk Guards / Stake Caps ────────────────────────────────
MAX_STAKE_PCT=0.015
MAX_STAKE_LONGSHOT_PCT=0.0075
LONGSHOT_ODDS_THRESHOLD=3.5
MIN_COMBO_LEG_CONFIDENCE=0.40

# ── Enrichment ───────────────────────────────────────────────
ENRICHMENT_ENABLED=true
ENRICHMENT_TIMEOUT=30

# ── Stats Ingestion ──────────────────────────────────────────
STATS_INGESTION_ENABLED=true
STATS_INGESTION_INTERVAL_HOURS=6

# ── ML Feature Pipeline ────────────────────────────────────
# Schema migration (required after update):
#   alembic upgrade head
#
# Backfill ALL features (phase 1-4):
#   python scripts/backfill_ml_features.py --dry-run     # preview
#   python scripts/backfill_ml_features.py --force        # full backfill
#   python scripts/backfill_ml_features.py --sport soccer # sport-specific
#
# Coverage report: generated automatically during training
#   -> ML_FEATURE_COVERAGE_REPORT.md
#   -> artifacts/feature_coverage.json
#
# CLV regressor: auto-falls back to legacy join if event_closing_lines.market
# column is missing (pre-migration). Run 'alembic upgrade head' to enable
# full market-aware CLV training across h2h/totals/spreads.
